{
  "data_dir": "trainingdatahourly",
  "symbols": "ETHUSD",
  "forecast_backend": "bootstrap",
  "context_window": 128,
  "prediction_length": 1,
  "realized_horizon": 1,
  "num_samples": 128,
  "num_timesteps": 150000,
  "learning_rate": 5e-05,
  "batch_size": 512,
  "n_steps": 2048,
  "gamma": 0.995,
  "gae_lambda": 0.98,
  "clip_range": 0.2,
  "costs_bps": 3.0,
  "turnover_penalty": 0.001,
  "drawdown_penalty": 0.05,
  "cvar_penalty": 0.25,
  "uncertainty_penalty": 0.05,
  "regime_filters_enabled": true,
  "regime_drawdown_threshold": 0.03,
  "regime_leverage_scale": 0.35,
  "policy_dtype": "bfloat16",
  "device": "auto",
  "use_wandb": false
}
