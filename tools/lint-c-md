#!/usr/bin/env bash
# lint-c-md — run cppcheck + clang-tidy on C/C++/CUDA sources and emit a token-efficient
# markdown report grouped by severity, with file:line links so agents can jump to source.
#
# Usage:  lint-c-md [--out report.md] [--clang-tidy] [--cppcheck-only] PATH [PATH...]
#
# Output sections:
#   ## Summary  (counts by severity)
#   ## Errors / Warnings / Style / Performance / Portability
#   Each finding: `path:line:col` — id — message  (one line each)
#
# Exit code: 0 if no errors, 1 if any error-severity finding.
set -euo pipefail

OUT=""
USE_TIDY=0
USE_CPPCHECK=1
PATHS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --out) OUT="$2"; shift 2;;
    --clang-tidy) USE_TIDY=1; shift;;
    --cppcheck-only) USE_TIDY=0; shift;;
    --no-cppcheck) USE_CPPCHECK=0; shift;;
    -h|--help) sed -n '2,15p' "$0"; exit 0;;
    *) PATHS+=("$1"); shift;;
  esac
done
[[ ${#PATHS[@]} -eq 0 ]] && { echo "lint-c-md: need at least one path"; exit 2; }

# Auto-pick a .cppcheck-suppress file from the first path's tree, if present.
for p in "${PATHS[@]}"; do
  d="$p"
  while [[ "$d" != "/" && "$d" != "." ]]; do
    if [[ -f "$d/.cppcheck-suppress" ]]; then
      CPPCHECK_SUPPR_FILE="$d/.cppcheck-suppress"
      break 2
    fi
    d="$(dirname "$d")"
  done
done

TMP=$(mktemp -d); trap 'rm -rf "$TMP"' EXIT
RAW="$TMP/cppcheck.txt"
TIDY="$TMP/tidy.txt"

# Cppcheck: machine-readable template, all checks except missingInclude noise.
if [[ $USE_CPPCHECK -eq 1 ]]; then
  cppcheck \
    --enable=warning,style,performance,portability \
    --inline-suppr \
    -i vendor -i external -i .pytest_tmp -i build -i .venv \
    --suppress='*:*/vendor/*' \
    --suppress='*:*/external/*' \
    --suppress='*:*/.pytest_tmp/*' \
    --suppress=missingIncludeSystem \
    --suppress=unusedFunction \
    --suppress=unmatchedSuppression \
    ${CPPCHECK_SUPPR_FILE:+--suppressions-list=$CPPCHECK_SUPPR_FILE} \
    --quiet \
    --template='{file}:{line}:{column}|{severity}|{id}|{message}' \
    "${PATHS[@]}" 2>"$RAW.full" 1>/dev/null || true
  # Drop vendored / upstream noise: cppcheck still follows includes into them.
  grep -Ev '(^|/)(vendor|external|\.pytest_tmp|build|\.venv)(/|$)|PufferLib/(vendor|ocean|src)/' "$RAW.full" > "$RAW" || true
fi

# Optional clang-tidy pass — slow, opt-in. Picks up bugprone, performance, readability.
if [[ $USE_TIDY -eq 1 ]]; then
  : > "$TIDY"
  while IFS= read -r -d '' f; do
    clang-tidy --quiet \
      -checks='-*,bugprone-*,clang-analyzer-*,performance-*,portability-*,readability-misleading-indentation,readability-non-const-parameter' \
      "$f" -- -I. -I include 2>/dev/null \
      | awk -v F="$f" '/warning:|error:/{print}' >> "$TIDY" || true
  done < <(find "${PATHS[@]}" -type f \( -name '*.c' -o -name '*.h' -o -name '*.cpp' -o -name '*.hpp' \) -print0)
fi

emit_md() {
  local total errs warns styles perfs ports
  errs=$(awk -F'|' '$2=="error"'      "$RAW" | wc -l)
  warns=$(awk -F'|' '$2=="warning"'    "$RAW" | wc -l)
  styles=$(awk -F'|' '$2=="style"'      "$RAW" | wc -l)
  perfs=$(awk -F'|' '$2=="performance"' "$RAW" | wc -l)
  ports=$(awk -F'|' '$2=="portability"' "$RAW" | wc -l)
  total=$((errs+warns+styles+perfs+ports))

  echo "# C lint report"
  echo
  echo "_Generated $(date -Iseconds) on $(hostname) — \`$(cppcheck --version 2>&1)\`_"
  echo
  echo "## Summary"
  echo
  echo "| Severity | Count |"
  echo "|---|---|"
  echo "| error | $errs |"
  echo "| warning | $warns |"
  echo "| style | $styles |"
  echo "| performance | $perfs |"
  echo "| portability | $ports |"
  echo "| **total** | **$total** |"
  echo
  echo "Paths scanned:"
  for p in "${PATHS[@]}"; do echo "- \`$p\`"; done
  echo

  for sev in error warning performance portability style; do
    local count
    count=$(awk -F'|' -v s="$sev" '$2==s' "$RAW" | wc -l)
    [[ $count -eq 0 ]] && continue
    echo "## ${sev^} ($count)"
    echo
    awk -F'|' -v s="$sev" '$2==s {printf "- `%s` — **%s** — %s\n", $1, $3, $4}' "$RAW" \
      | sort -u
    echo
  done

  if [[ $USE_TIDY -eq 1 && -s "$TIDY" ]]; then
    echo "## Clang-tidy ($(wc -l <"$TIDY"))"
    echo
    awk '{printf "- %s\n", $0}' "$TIDY" | head -200
    echo
  fi
}

if [[ -n "$OUT" ]]; then emit_md > "$OUT"; echo "wrote $OUT"; else emit_md; fi
errs=$(awk -F'|' '$2=="error"' "$RAW" | wc -l)
exit $(( errs > 0 ? 1 : 0 ))
